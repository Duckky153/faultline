# Copy to ".env" and fill in your Dynatrace trial values, then:  source .env
# (The real .env is gitignored — your token never gets committed.)
#
# Your Dynatrace OTLP endpoint looks like:
#   https://<your-env-id>.live.dynatrace.com/api/v2/otlp
# Your API token (made in Dynatrace > Access Tokens, scope: openTelemetryTrace.ingest)
# looks like:  dt0c01.XXXXXXXX...
export OTEL_EXPORTER_OTLP_ENDPOINT="https://<your-env-id>.live.dynatrace.com/api/v2/otlp"
export OTEL_EXPORTER_OTLP_HEADERS="Authorization=Api-Token dt0c01.YOUR_TOKEN_HERE"
export OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
